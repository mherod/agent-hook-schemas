{
  "name": "agent-hook-schemas",
  "version": "0.1.0",
  "description": "Zod schemas and helpers for AI coding assistant hook stdin/stdout and hooks config (Claude Code, Codex, Gemini CLI, Cursor).",
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./claude": {
      "types": "./dist/claude.d.ts",
      "import": "./dist/claude.js"
    },
    "./claude-hooks-integration": {
      "types": "./dist/claude-hooks-integration.d.ts",
      "import": "./dist/claude-hooks-integration.js"
    },
    "./codex": {
      "types": "./dist/codex.d.ts",
      "import": "./dist/codex.js"
    },
    "./common": {
      "types": "./dist/common.d.ts",
      "import": "./dist/common.js"
    },
    "./cursor": {
      "types": "./dist/cursor.d.ts",
      "import": "./dist/cursor.js"
    },
    "./gemini": {
      "types": "./dist/gemini.d.ts",
      "import": "./dist/gemini.js"
    },
    "./gemini-hooks-integration": {
      "types": "./dist/gemini-hooks-integration.d.ts",
      "import": "./dist/gemini-hooks-integration.js"
    }
  },
  "files": [
    "dist",
    "*.ts",
    "!*.test.ts",
    "!tsup.config.ts"
  ],
  "keywords": [
    "agent",
    "claude-code",
    "codex",
    "cursor",
    "gemini",
    "hooks",
    "schema",
    "zod"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mherod/agent-hook-schemas.git"
  },
  "bugs": {
    "url": "https://github.com/mherod/agent-hook-schemas/issues"
  },
  "homepage": "https://github.com/mherod/agent-hook-schemas#readme",
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "bun run build",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
